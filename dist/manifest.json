{
  "manifest_version": 3,
  "name": "Markdown Editor Extension",
  "version": "1.0.0",
  "description": "A Markdown editor in a new tab with import, export, and auto-save.",
  "action": {
    "default_title": "Open Markdown Editor"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "editor.html",
        "editor.css",
        "editor.js",
        "vendor/easymde.min.css",
        "vendor/easymde.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
